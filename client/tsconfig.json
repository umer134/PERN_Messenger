{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],

    "module": "ESNext",
    "moduleResolution": "bundler",

    "jsx": "react-jsx",

    "allowJs": true,
    "checkJs": false,

    "strict": true,
    "noImplicitAny": false,

    "skipLibCheck": false,
    "isolatedModules": true,

    "resolveJsonModule": true,
    "esModuleInterop": true,

    "noEmit": true
  },
  "include": ["src"]
}
